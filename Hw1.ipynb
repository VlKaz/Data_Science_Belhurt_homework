   "source": [
    "12.\tНаписать программу, которая принимает от пользователя два числа и выводит их произведение."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "4a3912f9-1b87-4a45-8bdf-8dad6c98a919",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Введите число a:  4\n",
      "Введите число b:  4\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Результат умножения 16.0\n"
     ]
    }
   ],
   "source": [
    "a = input(\"Введите число a: \")\n",
    "b = input(\"Введите число b: \")\n",
    "mult = float(a)*float(b)\n",
    "print(\"Результат умножения\",mult)"
   ]
